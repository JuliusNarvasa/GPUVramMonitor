<Window x:Class="GpuVramMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:GpuVramMonitor"
        xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
        mc:Ignorable="d"
        Title="GPU VRAM Monitor"
        Height="600" Width="900"
        MinWidth="650" MinHeight="350"
        Background="#1e1e1e"
        Foreground="#cccccc"
        FontFamily="Segoe UI"
        FontSize="13"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="BarColor" Color="#0078d4" />
        <SolidColorBrush x:Key="GridLineBrush" Color="#333333" />
        <SolidColorBrush x:Key="AltRowBrush" Color="#252526" />
        <SolidColorBrush x:Key="RowBrush" Color="#1e1e1e" />
        <SolidColorBrush x:Key="HeaderBgBrush" Color="#2d2d2d" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0078d4" />
        <SolidColorBrush x:Key="TextBrush" Color="#cccccc" />
        <SolidColorBrush x:Key="DimTextBrush" Color="#888888" />
        <SolidColorBrush x:Key="PopupBg" Color="#2d2d2d" />
        <SolidColorBrush x:Key="PopupBorder" Color="#555" />

        <!-- Flat-style ProgressBar -->
        <Style x:Key="FlatProgressBar" TargetType="ProgressBar">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="IsIndeterminate" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid MinHeight="{TemplateBinding MinHeight}" Height="{TemplateBinding Height}">
                            <Border x:Name="PART_Track" Background="#3a3a3a" CornerRadius="3" />
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" 
                                    CornerRadius="3" HorizontalAlignment="Left" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tray icon image -->
        <DrawingImage x:Key="TrayIcon">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#0078D4">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <PathGeometry>
                                <PathFigure StartPoint="4,4" IsClosed="False">
                                    <LineSegment Point="8,12" />
                                    <LineSegment Point="12,4" />
                                </PathFigure>
                            </PathGeometry>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <!-- Toggle switch style -->
        <Style x:Key="SettingsToggle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <!-- Tray icon menu (pure WPF, not native — avoids white icon column in native menus) -->
        <ContextMenu x:Key="TrayContextMenu" Background="#2d2d2d" Foreground="#cccccc" BorderBrush="#555" Padding="0">
            <ContextMenu.Template>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="#2d2d2d" BorderBrush="#555" BorderThickness="1" CornerRadius="4" Padding="0">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </ContextMenu.Template>
            <MenuItem Header="Exit" Click="TrayExit_Click">
                <MenuItem.Template>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="16,6,24,6" Cursor="Hand">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#383838" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </MenuItem.Template>
            </MenuItem>
        </ContextMenu>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════ Row 0: GPU Info & Total VRAM ═══════ -->
        <Border Grid.Row="0" Background="#2d2d2d" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding GpuName}"
                           FontSize="15" FontWeight="SemiBold" Foreground="#e0e0e0" VerticalAlignment="Center" />

                <TextBlock x:Name="VramHeaderText" Grid.Row="0" Grid.Column="2" FontSize="13" VerticalAlignment="Center" />

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0" Height="10">
                    <Border Background="#3a3a3a" CornerRadius="3" />
                    <Border x:Name="VramBar" Background="{StaticResource BarColor}" CornerRadius="3" HorizontalAlignment="Left" />
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════ Row 1: Controls ═══════ -->
        <Border Grid.Row="1" Background="#2d2d2d" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8"
                x:Name="ControlsBorder">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Refresh:" VerticalAlignment="Center" Margin="8,0,6,0" Foreground="{StaticResource DimTextBrush}" />
                <Slider x:Name="RefreshSlider" Minimum="1" Maximum="10" Value="2" Width="100"
                        TickFrequency="1" TickPlacement="None" IsSnapToTickEnabled="True"
                        VerticalAlignment="Center" ValueChanged="RefreshSlider_ValueChanged" />
                <TextBlock Text="{Binding Value, ElementName=RefreshSlider, StringFormat={}{0:F0}s}" 
                           VerticalAlignment="Center" Margin="4,0,16,0" Foreground="{StaticResource DimTextBrush}" Width="28" />

                <Rectangle Width="1" Fill="#444" Margin="4,0,8,0" />

                <CheckBox x:Name="ExcludeDwmCheck" Content="Exclude dwm" IsChecked="True"
                          VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{StaticResource TextBrush}"
                          Checked="ExcludeDwm_Changed" Unchecked="ExcludeDwm_Changed" />

                <Button x:Name="PauseButton" Content="⏸ Pause" Width="80" Height="26"
                        Click="PauseButton_Click"
                        Background="#3a3a3a" Foreground="#d4d4d4"
                        BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                        FontSize="12" />

                <Button Content="↻" Width="28" Height="26" Margin="6,0,0,0"
                        Click="RefreshNowButton_Click"
                        Background="#3a3a3a" Foreground="#d4d4d4"
                        BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                        ToolTip="Refresh now" FontSize="14" />

                <!-- Gear / Settings button -->
                <Button x:Name="SettingsButton" Content="⚙" Width="28" Height="26" Margin="6,0,0,0"
                        Click="SettingsButton_Click"
                        Background="#3a3a3a" Foreground="#d4d4d4"
                        BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                        ToolTip="Settings" FontSize="14" />
            </StackPanel>
        </Border>

        <!-- ═══════ Row 2: Process DataGrid + Loading + Settings Popup ═══════ -->
        <Grid Grid.Row="2">
            <!-- DataGrid (hidden until first load — see HasLoaded) -->
            <DataGrid x:Name="ProcessGrid"
                      Visibility="Collapsed"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Background="#1e1e1e"
                      Foreground="{StaticResource TextBrush}"
                      BorderBrush="#444" BorderThickness="1"
                      RowBackground="{StaticResource RowBrush}"
                      AlternatingRowBackground="{StaticResource AltRowBrush}"
                      AlternationCount="2"
                      ColumnHeaderHeight="32"
                      RowHeight="30"
                      FontSize="13"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      VirtualizingPanel.VirtualizationMode="Standard"
                      SelectionChanged="ProcessGrid_SelectionChanged">

                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#264f78" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#ffffff" />
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#264f78" />
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="*" MinWidth="140">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource HeaderBgBrush}" />
                                <Setter Property="Foreground" Value="#e0e0e0" />
                                <Setter Property="BorderBrush" Value="#444" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="Height" Value="32" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="80">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                <Setter Property="Background" Value="{StaticResource HeaderBgBrush}" />
                                <Setter Property="Foreground" Value="#e0e0e0" />
                                <Setter Property="BorderBrush" Value="#444" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,0" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="FontFamily" Value="Consolas" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="VRAM (MB)" Binding="{Binding VramDisplay}" Width="110">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                <Setter Property="Background" Value="{StaticResource HeaderBgBrush}" />
                                <Setter Property="Foreground" Value="#e0e0e0" />
                                <Setter Property="BorderBrush" Value="#444" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,0" />
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Setter Property="FontFamily" Value="Consolas" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Usage" Width="*" MinWidth="120">
                        <DataGridTemplateColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource HeaderBgBrush}" />
                                <Setter Property="Foreground" Value="#e0e0e0" />
                                <Setter Property="BorderBrush" Value="#444" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="8,0" />
                            </Style>
                        </DataGridTemplateColumn.HeaderStyle>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid Margin="4,3,12,3">
                                    <ProgressBar Value="{Binding BarWidthPercent}"
                                                 Style="{StaticResource FlatProgressBar}"
                                                 Height="18"
                                                 Foreground="{StaticResource BarColor}" />
                                    <TextBlock Text="{Binding BarWidthPercent, StringFormat={}{0:F0}%}"
                                               FontSize="11" Foreground="#e0e0e0"
                                               VerticalAlignment="Center" Margin="8,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Loading overlay (shown until first refresh completes) -->
            <Border x:Name="LoadingOverlay" Background="#1e1e1e" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Loading GPU processes..."
                               Foreground="{StaticResource DimTextBrush}"
                               FontSize="16"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Initializing performance counters..."
                               Foreground="#666"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- ═══════ Settings Popup (overlays DataGrid) ═══════ -->
            <Border x:Name="SettingsPopup" Visibility="Collapsed"
                    Background="{StaticResource PopupBg}"
                    BorderBrush="{StaticResource PopupBorder}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16"
                    Width="280"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,4,4,0">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="14" FontWeight="SemiBold"
                               Foreground="#e0e0e0" Margin="0,0,0,10" />

                    <CheckBox x:Name="StartOnBootCheck" Content="Start on boot"
                              Style="{StaticResource SettingsToggle}"
                              Click="SettingsCheckBox_Click" />

                    <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to tray on minimize"
                              Style="{StaticResource SettingsToggle}"
                              Click="SettingsCheckBox_Click" />

                    <CheckBox x:Name="MinimizeOnCloseCheck" Content="Minimize to tray on close"
                              Style="{StaticResource SettingsToggle}"
                              Click="SettingsCheckBox_Click" />

                    <Separator Background="#444" Margin="0,8" />

                    <TextBlock Text="Settings are saved automatically"
                               FontSize="11" Foreground="{StaticResource DimTextBrush}" />
                </StackPanel>
            </Border>

            <!-- ═══════ Process Action Bar (shown when a row is selected) ═══════ -->
            <Border x:Name="ProcessActionBar" Visibility="Collapsed"
                    Background="#2d2d2d" BorderBrush="#444" BorderThickness="1" CornerRadius="4"
                    Padding="10,3" VerticalAlignment="Bottom" Height="32" Margin="0,0,0,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="SelectedProcessText" VerticalAlignment="Center"
                               Foreground="#e0e0e0" FontSize="12" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="FindProcessBtn" Content="📁" Width="28" Height="22" Margin="0,0,4,0"
                                Click="FindProcess_Click" Background="#3a3a3a" Foreground="#ccc"
                                BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                                ToolTip="Open file location in Explorer" FontSize="12" />
                    </StackPanel>
                    <Button Grid.Column="3" x:Name="KillProcessBtn" Content="✕" Width="28" Height="22"
                            Click="KillProcess_Click" Background="#3a3a3a" Foreground="#FF4444"
                            BorderBrush="#555" BorderThickness="1" Cursor="Hand"
                            ToolTip="End task" FontSize="12" />
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════ Row 3: Status Bar ═══════ -->
        <Border Grid.Row="3" Background="#2d2d2d" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="10,5" Margin="0,6,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Foreground="{StaticResource DimTextBrush}" FontSize="11">
                    <Run Text="Processes: " />
                    <Run Text="{Binding ProcessCount}" FontWeight="SemiBold" Foreground="#ccc" />
                </TextBlock>

                <TextBlock Grid.Column="1" Foreground="{StaticResource DimTextBrush}" FontSize="11" Margin="20,0,0,0">
                    <Run Text="Last refresh: " />
                    <Run Text="{Binding LastRefreshTime}" Foreground="#ccc" />
                </TextBlock>

                <TextBlock Grid.Column="3" Foreground="#666" FontSize="10" VerticalAlignment="Center">
                    Per-process values may be overestimated (Windows limitation)
                </TextBlock>
            </Grid>
        </Border>
    <!-- ═══════ Tray Icon (inside Grid — non-visual overlay) ═══════ -->
    <tb:TaskbarIcon x:Name="TrayIcon"
                    IconSource="{StaticResource TrayIcon}"
                    ToolTipText="GPU VRAM Monitor"
                    TrayMouseDoubleClick="TrayIcon_DoubleClick"
                    TrayRightMouseUp="TrayIcon_RightClick"
                    Visibility="Visible" />
</Grid>
</Window>
